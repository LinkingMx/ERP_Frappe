# ERP Frappe - Development Environment Variables
# Referencia: https://github.com/frappe/frappe_docker/blob/main/docs/02-setup/04-env-variables.md

# Versions
FRAPPE_VERSION=version-16
ERPNEXT_VERSION=v16.15.1

# Database
DB_PASSWORD=123
DB_HOST=mariadb
DB_PORT=3306

# Redis
REDIS_CACHE=redis-cache:6379
REDIS_QUEUE=redis-queue:6379

# Site
FRAPPE_SITE_NAME_HEADER=development.localhost

# Ports (host:container)
HTTP_PUBLISH_PORT=8080

# Development settings
PYTHON_VERSION=3.14
NODE_VERSION=22
